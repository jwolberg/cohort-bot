# --- Discord ---
DISCORD_PUBLIC_KEY=your_discord_app_public_key_hex
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_application_id

# --- GitHub ---
GITHUB_TOKEN=ghp_your_personal_access_token

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your_key
SUMMARIZER_MODEL=claude-haiku-4-5

# --- Google Cloud ---
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
FIRESTORE_DATABASE=(default)
DIGEST_FANOUT_QUEUE=digest-fanout
FOLLOWUPS_QUEUE=interaction-followups

# Public Cloud Run URL of this service (used to build Cloud Task targets and as
# the default OIDC audience for inbound task/scheduler auth).
SERVICE_URL=https://digest-bot-xxxx.a.run.app
# Service account that mints OIDC tokens for enqueued tasks.
TASK_INVOKER_SA_EMAIL=digest-bot-sa@your-gcp-project-id.iam.gserviceaccount.com
# Override the audience required on inbound OIDC tokens (defaults to SERVICE_URL).
OIDC_AUDIENCE=

# Fallback admin bearer token when IAP is not fronting /admin/* (local dev).
ADMIN_TOKEN=

# Optional: bootstrap the Firestore config singleton's digest channel.
DEFAULT_DIGEST_CHANNEL_ID=

LOG_LEVEL=INFO

# --- Local development only ---
# Point the Firestore client at the local emulator (see README).
# FIRESTORE_EMULATOR_HOST=localhost:8080
